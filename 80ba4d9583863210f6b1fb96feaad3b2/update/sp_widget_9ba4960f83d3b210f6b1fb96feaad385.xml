        <client_script><![CDATA[api.controller = ['$scope', '$element', '$timeout', '$window', '$http', function($scope, $element, $timeout, $window, $http) {

    /* =========================================

       SERVICE NOW WIDGET CLIENT SCRIPT

       Phase 2: Rive 状态机与高保真登录路由绑定

       ========================================= */

    var c = this;

    

    // 1. 初始化 AngularJS 双向绑定变量

    c.username = '';

    c.password = '';

    c.language = 'en';

    c.showPwd = false;

    c.loading = false;

    c.btnText = 'Log in';

    c.btnClass = '';

    c.showError = false;



    // 2. Rive 状态机控制器变量声明

    var isChecking, numLook, isHandsUp, trigSuccess, trigFail;

    var riveInstance;



    // 3. 异步初始化 Rive 实例 (解决 AngularJS DOM 渲染延迟风险)

    $timeout(function() {

        try {

            var canvasEl = $element[0].querySelector('#rive-canvas');

            if (!canvasEl) {

                console.warn('Canvas 节点未就绪');

                return;

            }



            // 从 window 环境调用由 Widget Dependency 注入的 rive 库

            var riveObj = $window.rive;

            if (!riveObj) {

                console.error('致命错误: Rive 运行时未加载，请检查 Widget Dependencies 配置。');

                return;

            }



            riveInstance = new riveObj.Rive({
                // 必须替换为你的真实 attachment sys_id 路径
                src: '/sys_attachment.do?sys_id=a59cd24b8317b210f6b1fb96feaad3e9&sysparm_this_url=sp_widget.do%3Fsys_id%3D9ba4960f83d3b210f6b1fb96feaad385%26sysparm_record_list%3DORDERBYDESCsys_updated_on%26sysparm_record_row%3D1%26sysparm_record_rows%3D297%26sysparm_record_target%3Dsp_widget',
                canvas: canvasEl,
                autoplay: true,

                stateMachines: 'Login Machine',

                onLoad: function() {

                    riveInstance.resizeDrawingSurfaceToCanvas();

                    // 绑定动画控制节点

                    var inputs = riveInstance.stateMachineInputs('Login Machine');

                    if (inputs) {

                        inputs.forEach(function(input) {

                            if (input.name === 'isChecking') isChecking = input;

                            if (input.name === 'numLook')    numLook = input;

                            if (input.name === 'isHandsUp')  isHandsUp = input;

                            if (input.name === 'trigSuccess') trigSuccess = input;

                            if (input.name === 'trigFail')    trigFail = input;

                        });

                    }

                }

            });

        } catch (e) {

            console.error('Rive 实例化失败:', e);

        }

    }, 200); // 给予 200ms 缓冲期确保 DOM 完全绘制



    // 4. 输入交互与状态机绑定 (整合鼠标 2D 追踪与打字 1D 追踪)
    var isInputFocused = false;

    // A. 鼠标坐标劫持与视线强制映射
    var onMouseMove = function(e) {
        // 核心约束：若表单正处于聚焦、打字或捂眼状态，立即剥夺鼠标的控制权
        if (!numLook || isInputFocused || (isHandsUp && isHandsUp.value)) return;
        
        var percentX = e.clientX / $window.innerWidth;
        // 映射到 Rive 底层引擎要求的 -100 (极左) 到 100 (极右) 数值区间
        numLook.value = (percentX * 200) - 100;
        
        // 动态计算 Y 轴阈值：鼠标在屏幕下半部时头部低下，上半部时抬起
        if (isChecking) {
            isChecking.value = (e.clientY > ($window.innerHeight / 2));
        }
    };
    $window.addEventListener('mousemove', onMouseMove);

    // B. 表单焦点状态机优先级接管
    c.onFocusUser = function() {
        isInputFocused = true;
        if (isChecking) isChecking.value = true;
        if (isHandsUp) isHandsUp.value = false;
    };

    c.onBlurUser = function() {
        isInputFocused = false;
        if (isChecking) isChecking.value = false;
        if (numLook) numLook.value = 0; // 失焦时视线强制回正
    };

    c.onChangeUser = function() {
        if (!numLook) return;
        var len = c.username ? c.username.length : 0;
        var look = (len / 25) * 100 - 50;
        numLook.value = Math.max(-100, Math.min(100, look));
    };

    c.onFocusPassword = function() {
        isInputFocused = true;
        if (isHandsUp) isHandsUp.value = true;
        if (isChecking) isChecking.value = false;
    };

    c.onBlurPassword = function() {
        isInputFocused = false;
        if (isHandsUp) isHandsUp.value = false;
    };

    c.togglePassword = function() {
        c.showPwd = !c.showPwd;
        if (isHandsUp) {
            isHandsUp.value = !c.showPwd;
        }
    };



    // 5. ServiceNow 登录鉴权逻辑整合

    function getParameterByName(name) {

        var url = $window.location.href;

        name = name.replace(/[\[\]]/g, '\\$&');

        var regex = new RegExp('[?&]' + name + '(=([^&#]*)|&|#|$)');

        var results = regex.exec(url);

        if (!results) return null;

        if (!results[2]) return '';

        return decodeURIComponent(results[2].replace(/\+/g, ' '));

    }



    c.login = function() {

        if (!c.username || !c.password) return;



        c.loading = true;

        c.btnText = 'Authenticating...';

        c.btnClass = 'loading';

        c.showError = false;



        // 验证过程中强制放下双手并停止视线追踪

        if (isHandsUp) isHandsUp.value = false;

        if (isChecking) isChecking.value = false;



        var redirectUrl = getParameterByName('sysparm_redirect');

        var finalRedirect = redirectUrl ? redirectUrl : '?id=kokoro_volunteer'; 



        var params = {

            'user_name': c.username,

            'user_password': c.password,

            'sys_action': 'sysverb_login',

            'sysparm_login_url': finalRedirect 

        };



        // 预留 500ms 展示加载状态，随后发起系统认证

        $timeout(function() {

            $http({

                method: 'POST',

                url: '/login.do',

                headers: {'Content-Type': 'application/x-www-form-urlencoded'},

                transformRequest: function(obj) {

                    var str = [];

                    for(var p in obj) str.push(encodeURIComponent(p) + "=" + encodeURIComponent(obj[p]));

                    return str.join("&");

                },

                data: params

            }).then(function(response) {

                // HTTP 200 并不绝对代表密码正确，但此处依照 PDI 默认表单返回逻辑处理

                c.btnText = 'Welcome!';

                c.btnClass = 'success';

                if (trigSuccess) trigSuccess.fire();



                $timeout(function() {

                    $window.location.href = finalRedirect;

                }, 1200);

            }, function(error) {

                c.loading = false;

                c.btnText = 'Try again';

                c.btnClass = 'fail';

                c.showError = true;

                if (trigFail) trigFail.fire(); // 触发 Rive 拒绝摇头动画



                $timeout(function() { 

                    c.btnText = 'Log in'; 

                    c.btnClass = '';

                    c.password = ''; 

                }, 2000);

            });

        }, 500); 

    };

    

    // 全局回车键监听

    var handleEnter = function(e) {

        if (e.key === 'Enter') {

            $scope.$apply(function() { 

                if(!c.loading) c.login(); 

            });

        }

    };

    document.addEventListener('keydown', handleEnter);



    // 内存泄漏防护：销毁阶段释放实例与监听
    $scope.$on('$destroy', function() {
        document.removeEventListener('keydown', handleEnter);
        $window.removeEventListener('mousemove', onMouseMove);
        if (riveInstance) riveInstance.cleanup();
    });

}];]]></client_script>
