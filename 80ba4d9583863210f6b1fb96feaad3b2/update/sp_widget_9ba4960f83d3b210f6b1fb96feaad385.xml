        <template><![CDATA[<div class="kokoro-rive-login-wrapper">
  <div class="kokoro-login">

    <div class="rive-wrap">
      <canvas id="rive-canvas" width="320" height="320"></canvas>
    </div>

    <div class="card">
      <div class="card__header">
        <h1 class="card__title">Welcome back!</h1>
        <p class="card__sub">Operator Authentication</p>
      </div>

      <div class="field">
        <label>User name</label>
        <div class="wrap">
          <input type="text" 
                 ng-model="c.username" 
                 ng-focus="c.onFocusUser()" 
                 ng-blur="c.onBlurUser()"
                 ng-change="c.onChangeUser()"
                 placeholder="Enter your username" 
                 autocomplete="off"/>
        </div>
      </div>

      <div class="field">
        <label>Password</label>
        <div class="wrap">
          <input type="{{c.showPwd ? 'text' : 'password'}}" 
                 ng-model="c.password" 
                 ng-focus="c.onFocusPassword()" 
                 ng-blur="c.onBlurPassword()"
                 placeholder="Enter your password"/>
          <button class="eye" ng-click="c.togglePassword()" tabindex="-1">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
          </button>
        </div>
      </div>

      <div class="field">
        <label>Language</label>
        <select ng-model="c.language" 
                ng-focus="c.onFocusUser()" 
                ng-blur="c.onBlurUser()">
          <option value="en">English</option>
          <option value="ja">日本語</option>
          <option value="zh">中文</option>
        </select>
      </div>

      <div class="card__error" ng-class="{'show': c.showError}">Invalid username or password</div>
      <button class="card__btn" 
              ng-class="c.btnClass" 
              ng-click="c.login()" 
              ng-disabled="c.loading">
        {{c.btnText}}
      </button>
    </div>

    <div class="brand">KOKORO · Shelter System</div>
  </div>
</div>]]></template>
